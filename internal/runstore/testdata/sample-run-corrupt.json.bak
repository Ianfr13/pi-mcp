  "script": "export const meta = { name: 'judge_claims', description: 'Judge three simple claims and synthesize verdicts', phases: [{ title: 'Scan' }, { title: 'Final' }] };\n\nconst itemSchema = {\n  type: 'object',\n  additionalProperties: false,\n  required: ['claim', 'verdict', 'reason'],\n  properties: {\n    claim: { type: 'string' },\n    verdict: { type: 'string', enum: ['TRUE', 'FALSE'] },\n    reason: { type: 'string' }\n  }\n};\n\nconst finalSchema = {\n  type: 'object',\n  additionalProperties: false,\n  required: ['claims', 'overall'],\n  properties: {\n    claims: { type: 'array', minItems: 3, maxItems: 3, items: itemSchema },\n    overall: { type: 'string' }\n  }\n};\n\nphase('Scan');\nconst inputs = [\n  { label: 'claim A', text: 'A) The Earth orbits the Sun.' },\n  { label: 'claim B', text: 'B) Water boils at 10 degrees Celsius at sea level.' },\n  { label: 'claim C', text: 'C) 7 is a prime number.' }\n];\nconst claims = await parallel(inputs.map(item => () => agent(`Judge: ${item.text}`, { label: item.label, tier: 'small', schema: itemSchema })));\n\nphase('Final');\nreturn await agent(`Aggregate: ${JSON.stringify(claims)}`, { label: 'final synthesis', tier: 'small', schema: finalSchema });",
